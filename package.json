{
  "name": "laas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PROJECT LAAS — fully procedural open world in the browser (WebGPU)",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5174 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "arch": "depcruise src/game --config .dependency-cruiser.cjs",
    "ci": "npm run typecheck && npm run test:run && npm run arch && npm run build",
    "shoot": "tsx tools/shoot.ts",
    "compare": "tsx tools/compare.ts",
    "battery": "tsx tools/battery.ts"
  },
  "dependencies": {
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/three": "^0.184.1",
    "@webgpu/types": "^0.1.60",
    "dependency-cruiser": "^16.10.4",
    "happy-dom": "20.10.6",
    "playwright": "^1.50.0",
    "sharp": "^0.34.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.6"
  }
}
